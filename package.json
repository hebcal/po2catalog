{
  "name": "@hebcal/po2catalog",
  "version": "0.9.6",
  "description": "Generate Go golang.org/x/text message catalogues from Hebcal gettext .po files",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hebcal/po2catalog.git"
  },
  "bugs": {
    "url": "https://github.com/hebcal/po2catalog/issues"
  },
  "homepage": "https://github.com/hebcal/po2catalog#readme",
  "bin": {
    "po2catalog": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "generate": "tsx src/cli.ts",
    "verify": "tsx src/cli.ts --config repos.json --out generated --test && cd generated && go mod tidy && go test ./...",
    "test": "tsx --test test/*.test.ts"
  },
  "license": "BSD-2-Clause",
  "dependencies": {
    "gettext-parser": "^9.1.1"
  },
  "devDependencies": {
    "@hebcal/core": "^6.6.0",
    "@hebcal/hdate": "^0.22.5",
    "@hebcal/learning": "^6.9.5",
    "@hebcal/leyning": "^9.5.5",
    "@hebcal/locales": "^6.5.1",
    "@hebcal/rest-api": "^6.5.1",
    "@types/gettext-parser": "^9.0.0",
    "@types/node": "^26.1.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
